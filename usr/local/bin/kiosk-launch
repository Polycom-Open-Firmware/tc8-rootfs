#!/bin/sh
# kiosk-launch — start the weston compositor and the selected browser engine.
# Invoked by kiosk.service; environment comes from its EnvironmentFile
# (/etc/default/tc8-kiosk): KIOSK_URL, KIOSK_ENGINE, COG_OPTS, CHROMIUM_OPTS.
#
# Weston (kiosk-shell) is the compositor — chosen over cage because it is the
# reference Wayland implementation and, unlike the cage in Debian bookworm,
# emits wl_touch.frame, which strict clients (chromium, GTK, Qt) require for
# touch input. Weston runs as a background child; the browser then connects
# as a client and kiosk-shell fullscreens it.
#
# KIOSK_ENGINE selects the client:
#   webkit (default)  cog — lightweight, always present
#   chromium          /usr/bin/chromium (poly-app-chromium); falls back to cog
#                     with a warning if the binary is absent, so the kiosk never
#                     fails to start because an engine package isn't baked.
#   kodi              /usr/bin/kodi (poly-app-kodi) as a Wayland client — the
#                     media-player role. Same fallback rule.
. /etc/default/tc8-kiosk 2>/dev/null || true
URL="${KIOSK_URL:-https://duckduckgo.com/}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/1000}"
WD=wayland-1

# Bring up weston on the mxsfb scanout node. weston auto-selects the DRM card
# that has connectors (card1); card0 is the connector-less etnaviv render GPU.
/usr/bin/weston --config=/etc/tc8-kiosk/weston.ini --socket="$WD" \
	--log="$XDG_RUNTIME_DIR/weston.log" &
weston_pid=$!

# Wait for weston's wayland socket before launching the client.
i=0
while [ ! -S "$XDG_RUNTIME_DIR/$WD" ]; do
	kill -0 "$weston_pid" 2>/dev/null || { echo "kiosk: weston exited before its socket appeared" >&2; exit 1; }
	i=$((i + 1)); [ "$i" -ge 150 ] && { echo "kiosk: timed out waiting for weston socket" >&2; exit 1; }
	sleep 0.1
done
export WAYLAND_DISPLAY="$WD"

case "${KIOSK_ENGINE:-webkit}" in
kodi)
	if [ -x /usr/bin/kodi ]; then
		# Persistent Kodi home, first writable wins: facres (TC8 — prepared
		# kiosk-owned by tc8-persist-root.sh; survives reboots + reflashes),
		# /var/lib (C60 direct-rw root), runtime dir (ephemeral last resort).
		for h in /persist/kodi-home /var/lib/kodi-home "$XDG_RUNTIME_DIR/kodi-home"; do
			mkdir -p "$h" 2>/dev/null || true
			[ -w "$h" ] && { HOME=$h; break; }
		done
		export HOME
		# Seed per-panel Kodi config (idempotent; the home is kiosk-owned):
		# web server on (remote control + the photo-frame autostart), and
		# media sources from /etc/default/poly-media (MEDIA_SOURCE) plus
		# the always-present local /persist/media.
		. /etc/default/poly-media 2>/dev/null || true
		UD="$HOME/.kodi/userdata"; mkdir -p "$UD"
		GS="$UD/guisettings.xml"
		[ -f "$GS" ] || printf '<settings version="2">\n</settings>\n' > "$GS"
		# gs_set FILE ID VALUE — pin a guisettings value as a valued element,
		# not only-if-absent. Kodi records a default-valued setting as
		# default="true" and then ignores the element value, so a persisted
		# guisettings.xml (facres survives reflashes) can pin a setting to the
		# wrong value. Replace any existing entry (valued or self-closing),
		# else insert it.
		gs_set() {
			if grep -q "id=\"$2\"" "$1"; then
				sed -i -E "s#<setting id=\"$2\"[^>]*/>#<setting id=\"$2\">$3</setting>#; s#<setting id=\"$2\"[^>]*>[^<]*</setting>#<setting id=\"$2\">$3</setting>#" "$1"
			else
				sed -i "s|</settings>|    <setting id=\"$2\">$3</setting>\n</settings>|" "$1"
			fi
		}
		# Web server on (remote control + the photo-frame autostart).
		gs_set "$GS" services.webserver true
		gs_set "$GS" services.webserverauthentication false
		# TC8 (tas5751 SAI) audio: the codec is 48k-family + stereo-only and
		# Kodi disables ALSA resampling, so it opens the sink at the source
		# rate (e.g. 44100 mono) and the hardware rejects it. Pin a fixed
		# 48000/stereo output; Kodi resamples to it internally. Gated on the
		# card — the C60's codec has no such constraint.
		if grep -qi tas5751 /proc/asound/cards 2>/dev/null; then
			gs_set "$GS" audiooutput.config 1
			gs_set "$GS" audiooutput.samplerate 48000
			gs_set "$GS" audiooutput.channels 2
		fi
		SRC="$UD/sources.xml"
		if [ ! -f "$SRC" ] || grep -q "poly-media-setup" "$SRC"; then
			{
				printf '<!-- poly-media-setup: generated from /etc/default/poly-media; edits are overwritten -->\n<sources>\n'
				for sec in video music pictures files; do
					printf '    <%s>\n        <source><name>Local media</name><path pathversion="1">/persist/media/</path><allowsharing>true</allowsharing></source>\n' "$sec"
					[ -n "${MEDIA_SOURCE:-}" ] && printf '        <source><name>Media server</name><path pathversion="1">%s</path><allowsharing>true</allowsharing></source>\n' "$MEDIA_SOURCE"
					printf '    </%s>\n' "$sec"
				done
				printf '</sources>\n'
			} > "$SRC"
		fi
		exec /usr/bin/kodi --windowing=wayland --standalone -fs
	fi
	echo "kiosk: KIOSK_ENGINE=kodi but /usr/bin/kodi is missing — falling back to cog" >&2
	;;
chromium)
	if [ -x /usr/bin/chromium ]; then
		exec /usr/bin/chromium --kiosk --no-first-run --disable-infobars --disk-cache-size=104857600 \
			--ozone-platform=wayland ${CHROMIUM_OPTS} "$URL"
	fi
	echo "kiosk: KIOSK_ENGINE=chromium but /usr/bin/chromium is missing — falling back to cog" >&2
	;;
esac
exec /usr/bin/cog ${COG_OPTS} "$URL"
