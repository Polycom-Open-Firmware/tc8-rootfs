[Unit]
Description=Shared data partition (Android userdata)
DefaultDependencies=no
After=local-fs-pre.target
Before=local-fs.target umount.target
Conflicts=umount.target

[Mount]
What=/dev/mmcblk2p15
Where=/data
Type=ext4
Options=defaults,nofail,noatime,x-systemd.device-timeout=5s
TimeoutSec=15

[Install]
WantedBy=local-fs.target
